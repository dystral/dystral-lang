import { assert } from "std.core"
import { MutableList, MutableMap, Node, MutableSet, List, Map, Set, toJson } from "std.collections"

test "should add and read from MutableList" {
    val items: List<Int> = [10]
    val list: MutableList<Int> = MutableList(items)
    list.add(10)
    list.add(20)
    list.add(30)
    
    assert(list.size() == 4)
    assert(list.get(0) == 10)
    assert(list.get(1) == 10)
    assert(list.get(2) == 20)
    assert(list[3] == 30)

    list.set(1, 99)
    assert(list.get(1) == 99)
}

test "should add and read from MutableMap" {
    val dummy: Node<String, Int>? = null
    val bucketBuilder = MutableList([dummy])
    var i = 0
    while (i < 15) {
        bucketBuilder.add(null)
        i = i + 1
    }
    
    val map: MutableMap<String, Int> = MutableMap(bucketBuilder.list)
    
    map["Aether"] = 100
    map["Kotlin"] = 200
    map.put("Zig", 300)

    assert(map["Aether"] == 100)
    assert(map["Kotlin"] == 200)
    assert(map["Zig"] == 300)
    assert(map["Rust"] == null)

    assert(map.containsKey("Aether") == true)
    assert(map.containsKey("Rust") == false)

    // Update existing
    map["Aether"] = 999
    assert(map["Aether"] == 999)
}

test "should work with MutableSet" {
    val dummy: Node<String, Bool>? = null
    val bucketBuilder = MutableList([dummy])
    var i = 0
    while (i < 15) {
        bucketBuilder.add(null)
        i = i + 1
    }
    val map: MutableMap<String, Bool> = MutableMap(bucketBuilder.list)
    val set: MutableSet<String> = MutableSet(map)

    set.add("Aether")
    set.add("Zig")

    assert(set.contains("Aether") == true)
    assert(set.contains("Zig") == true)
    assert(set.contains("Kotlin") == false)
}
test "should infer types for MutableList" {
    val list = MutableList([10])
    list.add(20)
    
    assert(list.size() == 2)
    assert(list.get(0) == 10)
    assert(list.get(1) == 20)
}

test "should infer types for MutableMap" {
    val dummy: Node<String, Int>? = null
    val bucketBuilder = MutableList([dummy])
    var i = 0
    while (i < 15) {
        bucketBuilder.add(null)
        i = i + 1
    }
    
    val map = MutableMap(bucketBuilder.list)
    map.put("Aether", 100)
    
    assert(map.get("Aether") == 100)
}

test "should infer types for MutableSet" {
    val dummy: Node<String, Bool>? = null
    val bucketBuilder = MutableList([dummy])
    var i = 0
    while (i < 15) {
        bucketBuilder.add(null)
        i = i + 1
    }
    
    val map = MutableMap(bucketBuilder.list)
    val set = MutableSet(map)
    
    set.add("Inferred")
    assert(set.contains("Inferred") == true)
}

test "should infer types for List" {
    val list = [10, 20]
    
    assert(list.size() == 2)
    assert(list[0] == 10)
    assert(list[1] == 20)
}

test "should create map from literal" {
    val map = [
        "nome" of "Leo", 
        "cidade" of "Bauru"
    ]
    assert(map["nome"] == "Leo")
    assert(map["cidade"] == "Bauru")
    assert(map["idade"] == null)
}

test "should use brackets for getting from map" {
    val map = ["nome" of "Leo"]
    assert(map["nome"] == "Leo")
}

test "should infer types for Map" {
    val dummy: Node<String, Int>? = null
    val bucketBuilder = MutableList([dummy])
    var i = 0
    while (i < 15) {
        bucketBuilder.add(null)
        i = i + 1
    }
    
    // Pre-populate using mutable map
    val mmap = MutableMap(bucketBuilder.list)
    mmap.put("Immutable", 42)
    
    // Now wrap the same array in an immutable map
    val map = Map(bucketBuilder.list)
    
    assert(map.get("Immutable") == 42)
}

test "should infer types for Set" {
    val dummy: Node<String, Bool>? = null
    val bucketBuilder = MutableList([dummy])
    var i = 0
    while (i < 15) {
        bucketBuilder.add(null)
        i = i + 1
    }
    
    val mmap = MutableMap(bucketBuilder.list)
    mmap.put("Constant", true)

    val map = Map(bucketBuilder.list)
    val set = Set(map)
    
    assert(set.contains("Constant") == true)
}

test "should serialize Map to JSON string" {
    val dummy: Node<String, String>? = null
    val bucketBuilder = MutableList([dummy])
    var i = 0
    while (i < 15) {
        bucketBuilder.add(null)
        i = i + 1
    }
    
    val mmap = MutableMap(bucketBuilder.list)
    mmap.put("name", "Aether")
    mmap.put("version", "1.0")
    mmap.put("quotes", "a \"b\" c")
    mmap.put("backslash", "a\\b")

    val map = Map(bucketBuilder.list)
    val json = toJson(map)
    
    // Check that all key-value pairs are properly present in the JSON string
    assert(json.indexOf("\"name\": \"Aether\"") != -1)
    assert(json.indexOf("\"version\": \"1.0\"") != -1)
    assert(json.indexOf("\"quotes\": \"a \\\"b\\\" c\"") != -1)
    assert(json.indexOf("\"backslash\": \"a\\\\b\"") != -1)
}

