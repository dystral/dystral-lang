import { print } from "std.core"

type Address(val city: String, val zip: String) : Serializable + Json + Yaml

type Person(val name: String, val age: Int, val address: Address) : Serializable + Json

type NotSerializable(val x: Int)

type WithIgnored(val name: String, val extra: NotSerializable) : Serializable + Json

test "serializacao: pessoa com endereco aninhado em JSON" {
    val addr = Address("SP", "01000")
    val p = Person("Ana", 30, addr)
    assert(p.toJson() == "{\"name\": \"Ana\", \"age\": 30, \"address\": {\"city\": \"SP\", \"zip\": \"01000\"}}")
}

test "serializacao: yaml de endereco simples" {
    val addr = Address("RJ", "20000")
    val y = addr.toYaml()
    assert(y != "")
}

test "serializacao: campo nao serializavel ignorado" {
    val w = WithIgnored("test", NotSerializable(42))
    assert(w.toJson() == "{\"name\": \"test\"}")
}
