// Custom exception hierarchy
class CustomException(message: String) : Exception(message)
class AnotherException(message: String) : Exception(message)

fun throwError(shouldThrow: Bool) {
    if (shouldThrow) {
        throw CustomException("Custom error thrown")
    }
}

fun intermediateFunction(shouldThrow: Bool) {
    throwError(shouldThrow)
}

test "exception: basic throw and catch" {
    var caught = false
    var msg = ""
    try {
        throwError(true)
    } catch (e: CustomException) {
        caught = true
        msg = e.message
    }
    
    assert(caught == true)
    assert(msg == "Custom error thrown")
}

test "exception: stack propagation" {
    var caught = false
    try {
        intermediateFunction(true)
    } catch (e: CustomException) {
        caught = true
    }
    assert(caught == true)
}

test "exception: generic catch-all" {
    var caught = false
    try {
        throw AnotherException("oops")
    } catch {
        caught = true
    }
    assert(caught == true)
}

test "exception: multi-catch with union types" {
    var count = 0
    
    // Test catch of the first type
    try {
        throw CustomException("error 1")
    } catch (e: CustomException | AnotherException) {
        count = count + 1
        assert(e.message == "error 1")
        assert(e is CustomException)
        assert(e !is AnotherException)
    }
    
    // Test catch of the second type in the same block
    try {
        throw AnotherException("error 2")
    } catch (e: CustomException | AnotherException) {
        count = count + 1
        assert(e.message == "error 2")
        assert(e is AnotherException)
        assert(e !is CustomException)
    }
    
    assert(count == 2)
}

test "exception: rethrow of uncaught error" {
    var caughtLevel2 = false
    try {
        try {
            throw AnotherException("should propagate")
        } catch (e: CustomException) {
            // Should not catch AnotherException
            assert(false)
        }
    } catch (e: Exception) {
        caughtLevel2 = true
        assert(e.message == "should propagate")
    }
    assert(caughtLevel2 == true)
}

test "exception: try without catch swallows exceptions" {
    var executed = false
    try {
        throwError(true)
    }
    executed = true
    assert(executed == true)
}


