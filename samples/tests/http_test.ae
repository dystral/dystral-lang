import { Client } from "std.http"

test "http.ae: should perform HTTP GET request successfully" {
    val client = Client()
    val response = client.get("https://httpbin.org/get")

    assert(response != null)
    assert(response.status == 200)
    assert(response.body.length > 0)
}

test "http.ae: should perform HTTP POST request successfully" {
    val client = Client()
    val response = client.post("https://httpbin.org/post", "name=Aether&speed=Fast")

    assert(response != null)
    assert(response.status == 200)
    assert(response.body.length > 0)
}
