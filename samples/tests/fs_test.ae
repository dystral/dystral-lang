import { removeFile, readFile, writeFile } from "std.fs"

test "fs.ae: should write and read file correctly" {
    val path = "temp_test.txt"
    val content = "Hello, Aether Filesystem!"
    assert(writeFile(path, content))

    val result = readFile(path)
    assert(result == content)

    removeFile(path)
}

test "fs.ae: should support generic pointer types" {
    val intPtr: Pointer<Int> = Standard.gcMalloc(4)
    val voidPtr: OpaquePointer = intPtr
    val intPtr2: Pointer<Int> = voidPtr
    assert(intPtr == intPtr2)
}