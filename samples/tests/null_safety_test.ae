import { User } from "../null_safety"

test "null_safety.ae: should handle null safety operators correctly" {
    val u: User | null = null

    // Safe call on nullable user (should return null safely)
    val safeEmail: String? = u?.email

    // Elvis operator (should fallback)
    val fallback: User = u ?: User("Default", "default@email.com")
    
    // Not-null assertion (should extract the email from the fallback User)
    val forcedEmail: String = fallback.email!!
}
