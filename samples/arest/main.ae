import { arest } from "./arest"

import { date } from "std.time"
import { Json } from "std.json"
import { Yaml } from "std.yaml"

type Address(val city: String, val zip: String) : Serializable
type Person(val name: String, val age: Int, val address: Address, val birthday: Time, val tags: List<String>) : Serializable + Json + Yaml

fun main() {
    print("--- Starting Arest Web Server Sample ---")

    arest(8082) {
        routing {
            get("/") {
                val body = MutableMap<String, String>()
                body["welcome"] = "Hi there!"
                body["description"] = "Arest is a Web Framework for Aether!"
                body["date"] = now().toString()

                respond(200, "application/json", body.toJson())
            }

            get("/json") {
                val addr = Address("Sao Paulo", "01000-000")
                val person = Person("Ana", 30, addr, date(1987, 10, 10), ["friend", "coder"])
                respond(200, "application/json", person.toJson())
            }

            get("/yaml") {
                val addr = Address("Sao Paulo", "01000-000")
                val person = Person("Ana", 30, addr, date(1987, 10, 10), ["friend", "coder"])
                respond(200, "text/yaml", person.toYaml())
            }

            get("/hello") {
                val name = request.queries["name"] ?: "Guest"
                respondText("Hello, " + name + "!")
            }

            post("/echo") {
                val contentType = request.headers["Content-Type"] ?: "text/plain"
                respond(200, contentType, request.body)
            }

            get("/shutdown") {
                server.shutdown()
                respondText("Server is shutting down...")
            }
        }
    }
}
