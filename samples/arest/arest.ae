import { Server, ServerConnection, Request } from "std.http"
import { List, MutableList, Map, MutableMap, Node } from "std.collections"
import { Log } from "std.log"

type Route(val method: String, val path: String, val handler: ApplicationCall.() -> Void)

type RoutingBuilder(val routes: MutableList<Route?> = MutableList<Route?>()) {
    fun get(path: String, handler: ApplicationCall.() -> Void) {
        routes.add(Route("GET", path, handler))
    }
    
    fun post(path: String, handler: ApplicationCall.() -> Void) {
        routes.add(Route("POST", path, handler))
    }
    
    fun put(path: String, handler: ApplicationCall.() -> Void) {
        routes.add(Route("PUT", path, handler))
    }
    
    fun delete(path: String, handler: ApplicationCall.() -> Void) {
        routes.add(Route("DELETE", path, handler))
    }
}

type ArestBuilder(
    val port: Int,
    var running: Bool = true,
    val routingBuilder: RoutingBuilder = RoutingBuilder()
) {
    fun routing(init: RoutingBuilder.() -> Void) {
        init(routingBuilder)
    }

    fun shutdown() {
        running = false
    }
}

type ApplicationCall(
    val conn: ServerConnection,
    val request: Request,
    val server: ArestBuilder
) {
    fun respond(status: Int, contentType: String, body: String) {
        conn.writeResponse(status, contentType, body)
    }
    
    fun respondText(body: String, status: Int = 200) {
        respond(status, "text/plain", body)
    }
    
    fun respondHtml(body: String, status: Int = 200) {
        respond(status, "text/html", body)
    }
}

fun arest(port: Int, init: ArestBuilder.() -> Void) {
    val builder = ArestBuilder(port)
    init(builder)
    
    val server = Server()
    if (server.bind(port)) {
        Log.info { "[Arest] Server listening on port " + port.toString() + "..." }
        
        while (builder.running) {
            try {
                val conn = server.accept()
                if (conn != null) {
                    val req = conn!!.readRequest()
                    
                    // Match route
                    var found = false
                    var i = 0
                    val routes = builder.routingBuilder.routes
                    while (i < routes.size()) {
                        val route = routes.get(i)
                        if (route != null) {
                            val r = route!!
                            if (r.method == req.method && r.path == req.path) {
                                val call = ApplicationCall(conn!!, req, builder)
                                Log.info { "[Arest] HTTP " + req.method + " " + req.path + " -> 200 OK" }
                                r.handler(call)
                                found = true
                            }
                        }
                        i = i + 1
                    }
                    
                    if (found == false) {
                        Log.warn { "[Arest] HTTP " + req.method + " " + req.path + " -> 404 Not Found" }
                        conn!!.writeResponse(404, "text/plain", "Not Found")
                    }
                    
                    conn!!.close()
                }
            } catch (e) {
                Log.error(e) { "[Arest] Error processing connection" }
            }
        }
        
        server.close()
        Log.info { "[Arest] Server stopped gracefully." }
    } else {
        Log.error { "[Arest] Failed to bind to port " + port.toString() }
    }

}