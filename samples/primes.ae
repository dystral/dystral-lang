fun isPrime(n: Int): Bool {
    if (n <= 1) { return false }
    if (n <= 3) { return true }
    
    if (n - (n / 2) * 2 == 0) { return false }
    if (n - (n / 3) * 3 == 0) { return false }
    
    var i = 5
    while (i * i <= n) {
        if (n - (n / i) * i == 0) { return false }
        
        val next = i + 2
        if (n - (n / next) * next == 0) { return false }
        
        i = i + 6
    }
    
    return true
}

fun largestPrimeUpTo(max: Int): Int {
    var i = max
    while (i > 1) {
        if (isPrime(i)) {
            return i
        }
        i = i - 1
    }
    return 0
}
