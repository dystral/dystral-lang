import { lastUpTo } from "primes"

class Person(val name: String, var age: Int)

fun main(): Void {
    print("Starting loop...")
    
    while (true) {
        val prime = lastUpTo(1000000000)
        val prime2 = lastUpTo(1000000000)
        val p = Person("Leo", 38)

        print(p.name + " counted " + (prime + prime2).toString() + " prime numbers up to two billions")
        sleep(1)
    }
}
