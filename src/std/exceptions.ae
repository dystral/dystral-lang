contract Throwable {
    fun message(): String
}

type AssertionException(val text: String) : Throwable {
    implement fun message() = this.text
}

type Exception(val text: String) : Throwable {
    implement fun message() = this.text
}

fun error(msg: String): Void {
    throw Exception(msg)
}

fun assert(condition: Bool) {
    if (condition == false) {
        throw AssertionException("Assertion failed")
    }
}
