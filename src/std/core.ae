@Header("<stdlib.h>", "<stdio.h>")
lib Standard {
    fun sprintf(buffer: OpaquePointer, format: OpaquePointer, value: Int): Int

    @Alias("GC_MALLOC")
    fun gcMalloc(size: Int): OpaquePointer

    @Alias("GC_REALLOC")
    fun gcRealloc(ptr: OpaquePointer, newSize: Int): OpaquePointer
    
    fun exit(code: Int): Void
}

@Header("<string.h>")
lib NativeString {
    fun strcmp(s1: OpaquePointer, s2: OpaquePointer): Int
    
    fun strstr(haystack: OpaquePointer, needle: OpaquePointer): OpaquePointer
    
    fun strcpy(dest: OpaquePointer, src: OpaquePointer): OpaquePointer
    
    fun strncpy(dest: OpaquePointer, src: OpaquePointer, n: Int): OpaquePointer
    
    fun strlen(s: OpaquePointer): Int
    
    //TODO: Remove this, they are only for internal usage
    @Alias("aether_char_at")
    fun charAt(s: OpaquePointer, index: Int): Int
    
    @Alias("aether_terminate")
    fun terminate(s: OpaquePointer, index: Int): Void
}

contract Stringable {
    fun toString(): String
}

contract Equatable {
    operator fun equals(other: Stringable): Bool
}

contract Hashable {
    fun hashCode(): Int
}

@Primitive("pointer")
type OpaquePointer {}

@Primitive("pointer")
type Pointer<T> {}

type String(val ptr: OpaquePointer, val length: Int) : Stringable, Equatable, Hashable {
    implement fun toString(): String = this

    operator fun equals(other: String): Bool {
        return NativeString.strcmp(this.ptr, other.ptr) == 0
    }
    operator fun plus(other: String): String {
        val totalLen = this.length + other.length
        val buf = Standard.gcMalloc(totalLen + 1)
        Standard.sprintf(buf, "%s%s".ptr, this.ptr, other.ptr)
        return String(buf, totalLen)
    }

    fun replace(old: String, newStr: String): String {
        var count = 0
        var curr = this.ptr
        var searching = true
        
        while (searching) {
            val match = NativeString.strstr(curr, old.ptr)
            if (match != null) {
                count = count + 1
                curr = match + old.length
            } else {
                searching = false
            }
        }
        
        if (count == 0) { return this }
        
        val newLen = this.length + (count * (newStr.length - old.length))
        val res = Standard.gcMalloc(newLen + 1)
        
        curr = this.ptr
        var resCurr = res
        searching = true
        
        while (searching) {
            val match = NativeString.strstr(curr, old.ptr)
            if (match != null) {
                val prefixLen = match - curr
                NativeString.strncpy(resCurr, curr, prefixLen)
                resCurr = resCurr + prefixLen
                
                NativeString.strcpy(resCurr, newStr.ptr)
                resCurr = resCurr + newStr.length
                
                curr = match + old.length
            } else {
                NativeString.strcpy(resCurr, curr)
                searching = false
            }
        }
        
        
        return String(res, newLen)
    }

    fun indexOf(needle: String): Int {
        val match = NativeString.strstr(this.ptr, needle.ptr)
        if (match == null) { return -1 }
        return match - this.ptr
    }

    fun contains(other: String): Bool {
        return this.indexOf(other) != -1
    }


    fun substring(start: Int, end: Int): String {
        if (start < 0 || end > this.length || start > end) {
            return ""
        }
        val len = end - start
        val buf = Standard.gcMalloc(len + 1)
        NativeString.strncpy(buf, this.ptr + start, len)
        NativeString.terminate(buf, len)
        return String(buf, len)
    }

    fun hashCode(): Int {
        var hash = 5381
        var i = 0
        while (i < this.length) {
            val c = NativeString.charAt(this.ptr, i)
            hash = hash * 33 + c
            i = i + 1
        }
        return hash
    }
}

@Primitive("int")
type Int : Stringable, Equatable, Hashable {
    implement fun toString(): String {
        val buf = Standard.gcMalloc(32)
        Standard.sprintf(buf, "%d".ptr, this)
        return String(buf, NativeString.strlen(buf))
    }

    implement fun hashCode(): Int {
        return this
    }

    implement operator fun equals(other: Stringable): Bool {
        if (other is Int) {
            return this == other
        }
        return false
    }
}

@Primitive("bool")
type Bool : Stringable, Equatable, Hashable {
    implement fun toString(): String {
        return if (this) "true" else "false"
    }

    implement fun hashCode(): Int {
        return if (this) 1 else 0
    }

    implement operator fun equals(other: Stringable): Bool {
        if (other is Bool) {
            return this == other
        }
        return false
    }
}
